# ─────────────────────────────────────────────
# KrishiMitra — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

PORT=5000
FRONTEND_URL=http://localhost:5500

# ── Firebase Admin SDK ──────────────────────────────────────────────
# OPTION A (local dev): path to your downloaded service account JSON
FIREBASE_KEY_PATH=./config/serviceAccountKey.json

# OPTION B (production): paste values from the JSON file
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ── Firebase Web API Key (for login via REST) ───────────────────────
# Get this from: Firebase Console → Project Settings → General → Web API Key
FIREBASE_WEB_API_KEY=your-web-api-key-here
